<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Wilderness Survival Adventure (English)</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{
    background:#161616;
    color:#99ee99;
    font-family:Consolas, Arial;
    padding:20px;
    font-size:16px;
    line-height:1.7;
}
#container{
    max-width:700px;
    margin:0 auto;
}
#log{
    height:320px;
    overflow-y:auto;
    border:1px solid #4f8;
    padding:12px;
    margin-bottom:15px;
    background:#1a221a;
}
.bar{
    display:flex;
    gap:16px;
    margin-bottom:10px;
    color:#cf9;
}
.btns button{
    padding:7px 12px;
    margin:3px;
    border:none;
    background:#284;
    color:#fff;
    border-radius:3px;
    cursor:pointer;
}
.btns button:hover{background:#3a6;}
#bag{
    margin-top:12px;
    color:#ade;
}
</style>
</head>
<body>
<div id="container">
    <div class="bar">
        <div>HP: <span id="hp">100</span></div>
        <div>Hunger: <span id="food">100</span></div>
        <div>Time: <span id="time">Daytime</span></div>
        <div>Location: <span id="place">Forest Entrance</span></div>
    </div>

    <div id="log"></div>

    <div class="btns">
        <button onclick="go('forest')">Go Deep Into Forest</button>
        <button onclick="go('cave')">Explore Cave</button>
        <button onclick="collect()">Gather Supplies</button>
        <button onclick="talk()">Talk With Traveler</button>
        <button onclick="eat()">Eat Food</button>
        <button onclick="rest()">Take A Rest</button>
        <button onclick="fight()">Fight Wild Beast</button>
    </div>

    <div id="bag">Backpack: <span id="items">Empty</span></div>
</div>

<script>
let hp = 100;
let food = 100;
let isDay = true;
let place = "Forest Entrance";
let bag = [];
const logBox = document.getElementById('log');

function print(txt){
    let div = document.createElement('div');
    div.innerText = "> "+txt;
    logBox.appendChild(div);
    logBox.scrollTop = logBox.scrollHeight;
}

function refreshUI(){
    document.getElementById('hp').innerText = hp;
    document.getElementById('food').innerText = food;
    document.getElementById('time').innerText = isDay ? "Daytime" : "Night";
    document.getElementById('place').innerText = place;
    document.getElementById('items').innerText = bag.length ? bag.join(", ") : "Empty";

    if(food <= 0){
        hp -= 2;
        food = 0;
        print("You are starving and keep losing physical strength.");
    }
    if(hp <= 0){
        print("You collapsed in the wild. Game Over. Refresh to restart.");
    }
}

function timeTick(){
    isDay = !isDay;
    if(!isDay) print("The sky turns dark. It becomes much more dangerous at night.");
    else print("Sun rises, your vision gets clear again.");
    food -= 8;
    refreshUI();
}

function go(p){
    if(p === 'forest'){
        place = "Deep Woods";
        print("You walk into thick woods, hearing birds chirping around.");
        if(Math.random()>0.6) bag.push("Wild Berry");
    }else if(p === 'cave'){
        place = "Dark Cave";
        print("The cave is cold and damp, you move forward carefully.");
        if(Math.random()>0.5) bag.push("Herb");
        if(!isDay && Math.random()>0.7){
            print("A wolf jumps out from the cave!");
            fight();
        }
    }
    food -= 5;
    refreshUI();
}

function collect(){
    let r = Math.random();
    if(r>0.3){
        bag.push("Wild Berry");
        print("You picked a sweet wild berry.");
    }else if(r>0.6){
        bag.push("Firewood");
        print("You collected some firewood for making campfire.");
    }else{
        print("Nothing can be found here, the area is already picked clean.");
    }
    food -= 4;
    refreshUI();
}

function talk(){
    print("【Wandering Traveler】: Sigh, it’s really hard to survive in this wilderness.");
    setTimeout(()=>print("You: Where can I find food more easily?"),400);
    setTimeout(()=>print("Traveler: There are herbs inside the cave, but wild animals come out after dark. If you give me a berry, I can tell you a useful tip."),800);
    setTimeout(()=>{
        if(bag.includes("Wild Berry")){
            let idx = bag.indexOf("Wild Berry");
            bag.splice(idx,1);
            print("You hand the berry to him. Traveler: Thanks a lot! Resting recovers HP quickly, but you are likely to be attacked by monsters during night rest.");
        }else{
            print("Traveler: You don’t have any food, I can’t help you further.");
        }
    },1200);
    refreshUI();
}

function eat(){
    let idx = bag.indexOf("Wild Berry");
    if(idx !== -1){
        bag.splice(idx,1);
        food += 35;
        hp += 8;
        print("You eat the berry. Your hunger fades and you regain a little stamina.");
    }else{
        print("There is no edible food in your backpack.");
    }
    refreshUI();
}

function rest(){
    print("You lean against a big tree and take a break.");
    hp += 25;
    food -= 10;
    if(!isDay && Math.random()>0.65){
        hp -= 20;
        print("A beast ambushes you while resting at night, you get hurt badly!");
    }
    timeTick();
    refreshUI();
}

function fight(){
    print("A wild beast pounces toward you!");
    let power = Math.random()*30;
    let defend = Math.random()*20;
    let hurt = Math.max(0, power-defend);
    hp -= hurt;
    if(hurt>0){
        print("After fierce fighting, you take "+Math.round(hurt)+" damage.");
    }else{
        print("You dodge perfectly and chase the beast away. You obtain a piece of meat.");
        bag.push("Meat");
    }
    refreshUI();
}

print("Welcome to Wilderness Survival Adventure. You are lost in a strange wild land. Gather food, avoid beasts and try your best to stay alive.");
refreshUI();
</script>
</body>
</html>
