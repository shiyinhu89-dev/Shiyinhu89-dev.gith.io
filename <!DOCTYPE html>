<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>荒野文字生存冒险</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{
    background:#161616;
    color:#99ee99;
    font-family:Consolas,微软雅黑;
    padding:20px;
    font-size:16px;
    line-height:1.7;
}
#container{
    max-width:700px;
    margin:0 auto;
}
#log{
    height:320px;
    overflow-y:auto;
    border:1px solid #4f8;
    padding:12px;
    margin-bottom:15px;
    background:#1a221a;
}
.bar{
    display:flex;
    gap:16px;
    margin-bottom:10px;
    color:#cf9;
}
.btns button{
    padding:7px 12px;
    margin:3px;
    border:none;
    background:#284;
    color:#fff;
    border-radius:3px;
    cursor:pointer;
}
.btns button:hover{background:#3a6;}
#bag{
    margin-top:12px;
    color:#ade;
}
</style>
</head>
<body>
<div id="container">
    <div class="bar">
        <div>生命：<span id="hp">100</span></div>
        <div>饱食：<span id="food">100</span></div>
        <div>时间：<span id="time">白天</span></div>
        <div>地点：<span id="place">森林入口</span></div>
    </div>

    <div id="log"></div>

    <div class="btns">
        <button onclick="go('forest')">深入森林</button>
        <button onclick="go('cave')">探索山洞</button>
        <button onclick="collect()">采集物资</button>
        <button onclick="talk()">遇见旅人对话</button>
        <button onclick="eat()">吃东西</button>
        <button onclick="rest()">原地休息</button>
        <button onclick="fight()">遭遇野兽</button>
    </div>

    <div id="bag">背包：<span id="items">空</span></div>
</div>

<script>
let hp = 100;
let food = 100;
let isDay = true;
let place = "森林入口";
let bag = [];
const logBox = document.getElementById('log');

// 打印文字日志
function print(txt){
    let div = document.createElement('div');
    div.innerText = "> "+txt;
    logBox.appendChild(div);
    logBox.scrollTop = logBox.scrollHeight;
}

// 更新状态栏
function refreshUI(){
    document.getElementById('hp').innerText = hp;
    document.getElementById('food').innerText = food;
    document.getElementById('time').innerText = isDay ? "白天" : "黑夜";
    document.getElementById('place').innerText = place;
    document.getElementById('items').innerText = bag.length ? bag.join("、") : "空";

    // 饥饿扣血
    if(food <= 0){
        hp -= 2;
        food = 0;
        print("你太过饥饿，持续损失体力。");
    }
    if(hp <= 0){
        print("你倒在了荒野之中，游戏结束，请刷新页面重新开始。");
    }
}

// 切换昼夜
function timeTick(){
    isDay = !isDay;
    if(!isDay) print("天色暗了下来，夜晚更加危险。");
    else print("天亮了，视野变得清晰。");
    food -= 8;
    refreshUI();
}

// 移动场景
function go(p){
    if(p === 'forest'){
        place = "密林深处";
        print("你走进茂密的树林，耳边都是鸟鸣。");
        if(Math.random()>0.6) bag.push("野果");
    }else if(p === 'cave'){
        place = "幽暗山洞";
        print("山洞阴冷潮湿，你小心翼翼向前摸索。");
        if(Math.random()>0.5) bag.push("草药");
        if(!isDay && Math.random()>0.7){
            print("洞里窜出一只野狼！");
            fight();
        }
    }
    food -= 5;
    refreshUI();
}

// 采集
function collect(){
    let r = Math.random();
    if(r>0.3){
        bag.push("野果");
        print("采摘到一枚甜甜的野果。");
    }else if(r>0.6){
        bag.push("树枝");
        print("捡了一些木柴，可以用来生火。");
    }else{
        print("这片区域已经被采光了，什么都没找到。");
    }
    food -= 4;
    refreshUI();
}

// NPC文字互动
function talk(){
    print("【流浪旅人】：唉，这片荒野很难生存啊。");
    setTimeout(()=>print("你：这里哪里更容易找到食物？"),400);
    setTimeout(()=>print("旅人：往山洞那边走有草药，但是夜里会有野兽出没。如果你有野果，我可以告诉你一个小秘密。"),800);
    setTimeout(()=>{
        if(bag.includes("野果")){
            print("你拿出野果递给旅人。旅人：多谢！休息可以快速恢复生命值，但是夜里休息很容易被怪物偷袭。");
        }else{
            print("旅人：你没有食物，我没法再多说了。");
        }
    },1200);
    refreshUI();
}

// 吃东西
function eat(){
    let idx = bag.indexOf("野果");
    if(idx !== -1){
        bag.splice(idx,1);
        food += 35;
        hp += 8;
        print("吃掉野果，饥饿感缓解，体力恢复少许。");
    }else{
        print("背包里没有能吃的东西。");
    }
    refreshUI();
}

// 休息
function rest(){
    print("你靠着大树坐下休息。");
    hp += 25;
    food -= 10;
    if(!isDay && Math.random()>0.65){
        hp -= 20;
        print("黑夜休息时被野兽偷袭，受到伤害！");
    }
    // 每休息一次就更替昼夜
    timeTick();
    refreshUI();
}

// 战斗系统
function fight(){
    print("一头野兽朝你扑了过来！");
    let power = Math.random()*30;
    let defend = Math.random()*20;
    let hurt = Math.max(0, power-defend);
    hp -= hurt;
    if(hurt>0){
        print("搏斗过后，你受到了"+Math.round(hurt)+"点伤害。");
    }else{
        print("你灵巧躲开，成功赶跑了野兽，还捡到了肉块。");
        bag.push("肉块");
    }
    refreshUI();
}

// 开局
print("欢迎来到荒野生存冒险。你迷失在一片陌生的野外，需要搜集食物、躲避野兽，活下去。");
refreshUI();
</script>
</body>
</html>
